{
    "name": "ucubix/php-client",
    "description": "UCubix Distribution API PHP Client with built-in rate limiting and DTO support",
    "type": "library",
    "license": "MIT",
    "keywords": ["ucubix", "api", "client", "distribution", "license", "digital"],
    "authors": [
        {
            "name": "UCubix",
            "email": "dev@ucubix.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "guzzlehttp/guzzle": "^7.8",
        "spatie/laravel-data": "^4.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5|^11.0"
    },
    "autoload": {
        "psr-4": {
            "Ucubix\\PhpClient\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Ucubix\\PhpClient\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "sort-packages": true
    },
    "extra": {
        "branch-alias": {
            "dev-main": "1.0.x-dev"
        }
    }
}
